{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"],
      "@content/*": ["./src/content/*"],
      "@lib/*": ["./src/lib/*"],
    },
    "strictNullChecks": true,
  },
}
